<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

<androidx.cardview.widget.CardView
    android:id="@+id/plan_card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardElevation="4dp"
    app:cardCornerRadius="12dp"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 套餐头部：名称和流量 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/subscriptionName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="套餐名称"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>

                <TextView
                    android:id="@+id/subscriptionDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="流量信息"
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- 价格标签 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/subscriptionPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¥10"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"/>

                <TextView
                    android:id="@+id/subscriptionPriceUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="起/月"
                    android:textSize="12sp"
                    android:textColor="@color/gray"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- 价格选项区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 月付价格 -->
            <LinearLayout
                android:id="@+id/layout_month"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="@drawable/price_item_bg"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/text_month_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="月付"
                    android:textSize="12sp"
                    android:textColor="@color/gray"/>

                <TextView
                    android:id="@+id/text_month_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¥10"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- 季付价格 -->
            <LinearLayout
                android:id="@+id/layout_quarter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/price_item_bg"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/text_quarter_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="季付"
                    android:textSize="12sp"
                    android:textColor="@color/gray"/>

                <TextView
                    android:id="@+id/text_quarter_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¥28"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- 半年付价格 -->
            <LinearLayout
                android:id="@+id/layout_half_year"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/price_item_bg"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/text_half_year_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="半年"
                    android:textSize="12sp"
                    android:textColor="@color/gray"/>

                <TextView
                    android:id="@+id/text_half_year_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¥50"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- 年付价格 -->
            <LinearLayout
                android:id="@+id/layout_year"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/price_item_bg"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/text_year_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="年付"
                    android:textSize="12sp"
                    android:textColor="@color/gray"/>

                <TextView
                    android:id="@+id/text_year_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¥88"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 底部提示 -->
        <TextView
            android:id="@+id/subscriptionHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击价格选择周期，点击卡片进入详情"
            android:textSize="11sp"
            android:textColor="@color/gray"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
</layout>
