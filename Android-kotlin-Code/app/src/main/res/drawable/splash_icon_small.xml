<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 透明背景 -->
    <item android:drawable="@android:color/transparent" />
    <!-- 72dp 图标居中 -->
    <item
        android:width="72dp"
        android:height="72dp"
        android:gravity="center">
